# Public site URL (used for absolute links, metadata, sitemap)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Default locale (ar | en)
NEXT_PUBLIC_DEFAULT_LOCALE=ar

# Base URL of the backend API (Phase 2+). Leave empty to use the mock adapter.
NEXT_PUBLIC_API_BASE_URL=

# Map tile provider key (Phase 2 — business location features)
# NEXT_PUBLIC_MAPTILER_KEY=
